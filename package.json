{
  "name": "boilerbear",
  "version": "0.0.0",
  "private": true,
  "description": "Pick your stack. Get one command. Ship in minutes.",
  "license": "MIT",
  "author": "BoilerBear contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/BondeYash/BoilerBear"
  },
  "packageManager": "pnpm@11.1.3",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "validate-manifests": "turbo run validate-manifests",
    "new-module": "pnpm --filter @boilerbear/modules new-module",
    "clean": "turbo run clean && rm -rf node_modules",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,md}": ["biome check --write --no-errors-on-unmatched"]
  }
}
