{
  "name": "@boilerbear/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build",
    "start": "next start --port 3000",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install --with-deps chromium",
    "clean": "rm -rf .next .turbo test-results playwright-report"
  },
  "dependencies": {
    "@boilerbear/core": "workspace:*",
    "@boilerbear/modules": "workspace:*",
    "@boilerbear/ui": "workspace:*",
    "lucide-react": "^1.16.0",
    "next": "^16.2.6",
    "next-themes": "^0.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.1",
    "@boilerbear/config": "workspace:*",
    "@playwright/test": "^1.49.1",
    "@types/node": "^22.10.0",
    "@tailwindcss/typography": "^0.5.15",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.1",
    "autoprefixer": "^10.4.20",
    "axe-core": "^4.10.2",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.7.2"
  }
