{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "BoilerBear library",
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "composite": false,
    "incremental": true
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"]
}
